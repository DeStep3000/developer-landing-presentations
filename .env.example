DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
DJANGO_TIME_ZONE=Europe/Moscow

# Docker Compose uses these values for the PostgreSQL container.
DB_NAME=developer_landing
DB_USER=developer_landing
DB_PASSWORD=developer_landing
DB_HOST=db
DB_PORT=5432

# Optional for non-Docker deployments. If unset, local uv run uses SQLite.
# DATABASE_URL=postgres://user:password@host:5432/developer_landing

CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOW_ALL_ORIGINS=True

CONTACT_CREATE_RATE_LIMIT=5/min
CONTACTS_PAGE_SIZE=20
LOG_LEVEL=INFO
APP_PORT=8080

SITE_OWNER_EMAIL=owner@example.com
DEFAULT_FROM_EMAIL=no-reply@example.com
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True

# Optional AI integration. Without a key the service uses a deterministic fallback.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5
OPENAI_TIMEOUT_SECONDS=12
